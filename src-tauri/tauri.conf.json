{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeoSurgical WebGIS",
  "version": "0.1.0",
  "identifier": "com.geosurgical.webgis",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GeoSurgical WebGIS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
