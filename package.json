{
  "name": "geosurgical-webgis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "docker:up": "docker-compose up --build -d && echo \"\n🚀 WebGIS 容器已成功启动！\n👉 请按住 Ctrl 并在浏览器打开: http://localhost:8080\n\"",
    "docker:down": "docker-compose down",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "generate:types": "node scripts/generate-types.mjs",
    "generate:zod": "node scripts/generate-zod.mjs",
    "generate:rust": "node scripts/generate-rust.mjs",
    "generate:prompt": "node scripts/generate-prompt.mjs",
    "generate:all": "node scripts/generate-types.mjs && node scripts/generate-zod.mjs && node scripts/generate-rust.mjs && node scripts/generate-prompt.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "ol": "^10.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
