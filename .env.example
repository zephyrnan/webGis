# LLM Brain Configuration
# SECURITY: Vite injects VITE_* values into browser JS at build time.
# Do NOT use remote API keys in production — use a local Ollama instance instead.

# Brain mode: "llm" or "mock" (default: auto-detect based on endpoint)
VITE_BRAIN_MODE=llm

# LLM API endpoint (Ollama default: http://localhost:11434)
VITE_LLM_ENDPOINT=http://localhost:11434

# API key — NOT needed for local Ollama. Do NOT set for production builds.
# VITE_LLM_API_KEY=

# Model name (default: qwen2.5:7b for Ollama)
VITE_LLM_MODEL=qwen2.5:7b
