# LLM Brain 配置
# 安全提醒：Vite 会在构建时把 VITE_* 变量注入浏览器 JS。
# 写入前端代码的 API key 对所有用户可见。
# 生产环境：请使用后端代理，让 API key 保留在服务端。
# 本地开发：推荐使用 Ollama，不需要 API key。

# Brain 模式："llm" 或 "mock"（默认会根据 endpoint 自动判断）
VITE_BRAIN_MODE=llm

# LLM API endpoint。
# 本地 Ollama 示例：http://localhost:11434
# OpenAI-compatible 开发示例：https://api.openai.com、https://api.deepseek.com、https://api.siliconflow.cn
VITE_LLM_ENDPOINT=http://localhost:11434

# API key：本地 Ollama 不需要。生产前端构建不要设置真实远程 API key。
# 如果必须使用远程 API，请部署后端代理，由服务端携带 API key 转发请求，
# 然后把 VITE_LLM_ENDPOINT 指向你的代理地址。
# VITE_LLM_API_KEY=

# 模型名（Ollama 默认：qwen2.5:7b）
VITE_LLM_MODEL=qwen2.5:7b

# Sentry 错误监控（可选；留空即禁用）
# VITE_SENTRY_DSN=

# Tauri 桌面端 LLM 代理配置
# Tauri Rust 后端在开发模式下读取项目根目录 .env 中的 TAURI_LLM_*，不会把 API key 注入前端 JS。
# 本地 Ollama 示例：http://localhost:11434
# OpenAI-compatible 示例：https://api.openai.com、https://api.deepseek.com、https://api.siliconflow.cn
TAURI_LLM_ENDPOINT=http://localhost:11434
TAURI_LLM_MODEL=qwen2.5:7b
# TAURI_LLM_API_KEY=
