# LLM Brain Configuration
# SECURITY WARNING: Vite injects VITE_* values into browser JS at build time.
# API keys embedded in frontend code are VISIBLE to all users.
# For production: use a backend proxy to keep API keys server-side.
# For local development: use Ollama (no API key needed).

# Brain mode: "llm" or "mock" (default: auto-detect based on endpoint)
VITE_BRAIN_MODE=llm

# LLM API endpoint (Ollama default: http://localhost:11434)
VITE_LLM_ENDPOINT=http://localhost:11434

# API key — NOT needed for local Ollama. Do NOT set for production frontend builds.
# If you must use a remote API, deploy a backend proxy that forwards requests
# with the API key server-side, and point VITE_LLM_ENDPOINT to your proxy.
# VITE_LLM_API_KEY=

# Model name (default: qwen2.5:7b for Ollama)
VITE_LLM_MODEL=qwen2.5:7b

# Sentry error monitoring (optional — leave empty to disable)
# VITE_SENTRY_DSN=
